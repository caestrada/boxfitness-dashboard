* text=auto eol=lf

# Source
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# Lockfiles — keep LF, skip diff noise
package-lock.json   text eol=lf -diff
yarn.lock           text eol=lf -diff
pnpm-lock.yaml      text eol=lf -diff

# Binary assets
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.avif      binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.mp4       binary
*.mov       binary
*.zip       binary
